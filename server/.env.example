# ============================================
# BACKEND - Variáveis de Ambiente
# ============================================

# W-API WhatsApp Configuration (obrigatório)
# Obtenha suas credenciais em: https://w-api.app
# Dashboard -> Instâncias -> Copie Instance ID e Token
WAPI_INSTANCE_ID=seu_instance_id_aqui
WAPI_TOKEN=seu_token_w_api_aqui

# Supabase Backend Configuration (obrigatório)
# Acesse: https://app.supabase.com -> Settings -> API
# - URL: Project URL
# - SERVICE_ROLE_KEY: service_role (secret key)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=seu_service_role_key_aqui

# Server Configuration
PORT=3001

# Cron Job Configuration
# CRON_TIME: Horário simples no formato HH:MM (ex: "09:00", "14:30")
# CRON_SCHEDULE: Expressão cron completa (ex: "0 9 * * *", "*/5 * * * *")
# - Se ambos definidos, CRON_TIME tem prioridade
# - Padrão: "0 9 * * *" (09:00 diariamente)
# CRON_TIME=09:00
# CRON_SCHEDULE=0 9 * * *

# SEND_ON_STARTUP: Define se envia mensagens ao iniciar o servidor
# - true: Envia mensagens imediatamente ao iniciar (útil para testes/desenvolvimento)
# - false: Só envia no horário agendado via cron job
SEND_ON_STARTUP=false
