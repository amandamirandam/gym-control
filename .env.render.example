# ============================================
# RENDER - Variáveis de Ambiente
# ============================================
# Copie estas variáveis para o dashboard do Render ao fazer deploy

# ============================================
# BACKEND SERVICE (gym-control-server)
# ============================================

# W-API WhatsApp Configuration (obrigatório)
# Dashboard W-API: https://w-api.app
WAPI_INSTANCE_ID=
WAPI_TOKEN=

# Supabase Backend Configuration (obrigatório)
# Dashboard Supabase: https://app.supabase.com -> Settings -> API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Server Configuration
PORT=3001

# SEND_ON_STARTUP: Define se envia mensagens ao iniciar o servidor
# - false (recomendado para produção): Só envia no cron job (09:00)
# - true (apenas para testes): Envia ao iniciar
SEND_ON_STARTUP=false

# Segurança - Token para autenticar requisições ao endpoint
# Gere um token forte: openssl rand -hex 32
CRON_SECRET=

# ============================================
# FRONTEND SERVICE (gym-control-frontend)
# ============================================

# Supabase Frontend Configuration (obrigatório)
# Dashboard Supabase: https://app.supabase.com -> Settings -> API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Backend API URL (configurado automaticamente no Blueprint)
# Se deploy manual: https://seu-backend.onrender.com
# VITE_API_URL=

# ============================================
# NOTAS IMPORTANTES
# ============================================
# 
# 1. NUNCA commite este arquivo com valores reais!
# 2. Configure estas variáveis no Dashboard do Render
# 3. Para gerar CRON_SECRET: openssl rand -hex 32
# 4. Use service_role key apenas no backend (nunca exponha!)
# 5. Use anon key no frontend (é segura para expor)
# 6. VITE_API_URL é auto-configurado se usar Blueprint (render.yaml)
