# ============================================
# FRONTEND - Variáveis de Ambiente (.env.local)
# ============================================

# Supabase Configuration (obrigatório)
# Obtenha em: https://app.supabase.com -> Settings -> API
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Backend API URL (opcional - padrão: http://localhost:3001)
VITE_API_URL=http://localhost:3001


# ============================================
# BACKEND - Variáveis de Ambiente (server/.env)
# ============================================

# W-API WhatsApp Configuration (obrigatório)
# Obtenha suas credenciais em: https://w-api.app
WAPI_INSTANCE_ID=seu_instance_id_aqui
WAPI_TOKEN=seu_token_w_api_aqui

# Supabase Backend Configuration (obrigatório)
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Server Configuration
PORT=3001
# SEND_ON_STARTUP: true = envia mensagens ao iniciar (útil para testes)
#                  false = só envia no cron job (09:00 diariamente)
SEND_ON_STARTUP=false
